# ── Fraud Detection Demo v3.1 — Environment Configuration ─────────────────
# Copy this file to .env and fill in values for your environment.
# Leave FlashBlade paths blank to use Docker named volumes (local dev mode).

# ── FlashBlade NFS mounts (production) ────────────────────────────────────
# When set, docker-compose uses bind mounts to these paths instead of named volumes.
# Example: /mnt/flashblade/fraud/raw
FB_RAW_PATH=
FB_FEATURES_PATH=
FB_MODELS_PATH=

# ── Data Generation ────────────────────────────────────────────────────────
NUM_WORKERS=8
CHUNK_SIZE=100000
TARGET_ROWS=1000000
FRAUD_RATE=0.005

# 'once' = generate TARGET_ROWS and exit (use for pipeline demo)
# 'continuous' = loop indefinitely generating batches (use for live dashboard demo)
RUN_MODE=once

# Optional: path to seed CSV/ZIP (Sparkov or Kaggle CC Fraud format)
# If blank, falls back to hardcoded statistical defaults.
# Example: /data/seeds/credit_card_transactions.csv.zip
KAGGLE_SEED_PATH=

# ── Model Training ─────────────────────────────────────────────────────────
MAX_SAMPLES=500000

# ── Docker Compose ─────────────────────────────────────────────────────────
COMPOSE_PROJECT=fraud-det-v31

# ── NVIDIA NGC API key (required to pull nvcr.io images) ──────────────────
# Generate at: https://ngc.nvidia.com/setup/api-key
NVIDIA_API_KEY=
